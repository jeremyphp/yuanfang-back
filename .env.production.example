# Production Environment Variables
# Copy this file to .env.production and update values

# Server
PORT=5000
NODE_ENV=production

# Database
# For production, consider using PostgreSQL instead of SQLite
# PostgreSQL example: DATABASE_URL="postgresql://user:password@host:5432/dbname"
DATABASE_URL="file:./prod.db"

# JWT
JWT_SECRET="your-production-jwt-secret-change-this-to-a-strong-random-string"
JWT_EXPIRES_IN="7d"

# CORS
# Update with your frontend production URL
FRONTEND_URL="https://your-frontend-domain.vercel.app"

# Admin (update for production)
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="strong-production-password"

# API Documentation
API_DOCS_PATH="/api-docs"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Email (required for invitation emails in production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# AI APIs (optional)
# GEMINI_API_KEY=your-google-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AI Limits
AI_MAX_TOKENS_PER_DAY=100000
AI_MAX_MESSAGES_PER_DAY=100