generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  username      String?
  avatar        String?
  phone         String?
  balance       Float     @default(0)
  points        Int       @default(0)
  membership    String    @default("普通会员")
  status        String    @default("active")
  referrerId    String?   // 邀请人ID
  referralCode  String    @unique @default(uuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  services      Service[]
  orders        Order[]
  invites       Invite[]  @relation("ReferrerInvites")
  invitedBy      Invite?   @relation("InviteeInvites")
  chatSessions  ChatSession[]
  transactions  Transaction[]
}

model Service {
  id              String    @id @default(cuid())
  title           String
  description     String
  category        String    // tutorial, online, onsite
  price           Float
  coverImage      String?
  deliveryMethod  String    // tutorial, online, onsite
  coverage        Int       @default(20)
  status          String    @default("draft")
  userId          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders          Order[]
}

model Order {
  id              String    @id @default(cuid())
  orderNumber     String    @unique
  userId          String
  serviceId       String
  amount          Float
  paymentMethod   String    // wechat, alipay
  paymentStatus   String    @default("pending") // pending, paid, failed, refunded
  transactionId   String?
  status          String    @default("pending") // pending, processing, completed, cancelled
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  service         Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Invite {
  id              String    @id @default(cuid())
  referrerId      String    // 邀请人
  inviteeId       String?   @unique // 被邀请人（注册后关联）
  inviteeEmail    String?
  inviteCode      String
  status          String    @default("pending") // pending, accepted, expired
  rewardAmount    Float     @default(0)
  rewardStatus    String    @default("pending") // pending, paid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  referrer        User      @relation("ReferrerInvites", fields: [referrerId], references: [id], onDelete: Cascade)
  invitee         User?     @relation("InviteeInvites", fields: [inviteeId], references: [id], onDelete: SetNull)
}

model ChatSession {
  id              String    @id @default(cuid())
  userId          String
  title           String    @default("新对话")
  messages        Json      // 存储消息数组
  aiModel         String    @default("gemini-pro")
  tokenCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id              String    @id @default(cuid())
  key             String    @unique
  value           String
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Transaction {
  id              String    @id @default(cuid())
  userId          String
  type            String    // 'invite_reward', 'purchase', 'withdrawal', 'refund', 'commission'
  amount          Float
  status          String    @default("completed") // 'pending', 'completed', 'failed', 'cancelled'
  description     String?
  referenceId     String?   // Reference to invite_id, order_id, etc.
  metadata        Json      @default("{}") // JSON metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}